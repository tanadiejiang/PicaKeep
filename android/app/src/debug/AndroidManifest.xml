<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Debug-only launcher entry on MainActivity.

         The release/main manifest intentionally keeps MAIN/LAUNCHER only on
         the <activity-alias> entries (so the icon-switcher shows exactly one
         home-screen icon). But `flutter run` resolves the launch activity by
         scanning <activity> elements only — it ignores <activity-alias> — and
         fails with "package identifier or launch activity not found" when
         MainActivity has no launcher filter. This debug overlay adds the
         filter back for debug builds only; it is never merged into release. -->
    <application>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            tools:node="merge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
