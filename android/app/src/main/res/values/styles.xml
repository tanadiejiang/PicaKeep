<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light splash theme -->
    <style name="SplashThemeLight" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/launch_splash_icon</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>

    <!-- Dark splash theme -->
    <style name="SplashThemeDark" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1C1B1F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/launch_splash_icon</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>

    <!-- Default splash theme used in AndroidManifest (follows system uiMode via -night variant) -->
    <style name="SplashTheme" parent="SplashThemeLight" />

    <!-- Legacy launch theme kept for activity-alias entries -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Normal theme applied after splash -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
</resources>
